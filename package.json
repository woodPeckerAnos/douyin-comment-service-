{
  "name": "douyin-comment-service",
  "version": "1.0.0",
  "description": "Batch fetch Douyin video comments via Playwright with shared browser profile",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "fetch": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:browsers": "node node_modules/playwright-core/cli.js install chromium",
    "postinstall": "node node_modules/playwright-core/cli.js install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@koa/bodyparser": "^6.1.0",
    "@koa/router": "^15.6.0",
    "dotenv": "^17.4.2",
    "koa": "^3.2.1",
    "playwright-core": "^1.52.0",
    "yaml": "^2.7.1",
    "zod": "^4.4.3",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.4",
    "@types/koa": "^3.0.3",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
