PORT=3001
DATABASE_URL=postgres://dev:changeme@localhost:5432/douyin_comment
HEADLESS=true
BROWSER_CHANNEL=chrome
BROWSER_PROFILE_DIR=/Users/woodpeckeranos/Projects/content-discovery-service/profiles/douyin
MAX_COMMENTS_PER_VIDEO=500
HIGH_REPLY_THRESHOLD=10
REQUEST_DELAY_MS=1500
JOBS_DIR=./jobs
RESULTS_DIR=./results
PAGE_WAIT_MS=3000
SCROLL_DELAY_MS=1500
MAX_PAGES_PER_VIDEO=50

# 分层抽样（默认开启）：先 over-fetch 再按配额抽样至 MAX_COMMENTS_PER_VIDEO
SAMPLING_ENABLED=true
SAMPLING_OVER_FETCH_TARGET=1500

# Redis / job-queue（连接 Docker 内 Redis，端口映射到宿主机）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
QUEUE_NAME=jobs
QUEUE_DEFAULT_JOB_NAME=douyin_fetch_comments
# QUEUE_JOB_NAMES=douyin_fetch_comments
WORKER_CONCURRENCY=1
WORKER_NAME=douyin-comment
