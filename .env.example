PORT=3001
HEADLESS=true
BROWSER_CHANNEL=chrome
BROWSER_PROFILE_DIR=/Users/woodpeckeranos/Projects/content-discovery-service/profiles/douyin
MAX_COMMENTS_PER_VIDEO=500
HIGH_REPLY_THRESHOLD=10
REQUEST_DELAY_MS=1500
JOBS_DIR=./jobs
RESULTS_DIR=./results
PAGE_WAIT_MS=3000
SCROLL_DELAY_MS=1500
MAX_PAGES_PER_VIDEO=50

# 分层抽样（默认开启）：先 over-fetch 再按配额抽样至 MAX_COMMENTS_PER_VIDEO
SAMPLING_ENABLED=true
SAMPLING_OVER_FETCH_TARGET=1500
